msgctxt "Addon Summary"
msgid "Nintendo - SNES / SFC (bsnes-mercury Performance)"
msgstr "Nintendo - SNES / SFC (bsnes-mercury Performance)"

msgctxt "Addon Description"
msgid "bSNES Mercury is a fork of Higan (originally called bSNES), notable for emulating the original hardware as accurately as possible through low-level, cycle-accurate emulation.[CR][CR]The [I]Performance[/I] profile focuses more on execution speed than on accuracy."
msgstr "bSNES Mercury je verze odvozená od emulátoru Higan (původně nazývaného bSNES), známá tím, že emuluje původní hardware co nejpřesněji pomocí nízkoúrovňové, cyklově přesné emulace.[CR][CR]Profil [I]Performance[/I] se zaměřuje více na rychlost běhu než na přesnost."

msgctxt "Addon Disclaimer"
msgid "In loving memory of Near / Byuu"
msgstr "S láskou na památku Near / Byuu"

msgctxt "#30001"
msgid "Allow settings to reduce accuracy"
msgstr "Povolit nastavení snižující přesnost"

msgctxt "#30002"
msgid "Special chip accuracy"
msgstr "Přesnost speciálních čipů"

msgctxt "#30003"
msgid "SuperFX speed"
msgstr "Rychlost SuperFX"

msgctxt "#30004"
msgid "System region"
msgstr "Region systému"

msgctxt "#30005"
msgid "Preferred aspect ratio"
msgstr "Preferovaný poměr stran"

msgctxt "#30006"
msgid "Crop overscan"
msgstr "Oříznout overscan"

msgctxt "#30007"
msgid "Gamma ramp (requires restart)"
msgstr "Gama rampa (vyžaduje restart)"
